    "cors": "^2.8.5",
    "crawlee": "^3.16.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.1",
    "google-auth-library": "^10.5.0",
    "helmet": "^7.1.0",
    "http-errors": "^2.0.0",
    "http-status": "^2.1.0",
    "https-proxy-agent": "^8.0.0",
    "joi": "^18.0.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.20.4",
    "multer": "^1.4.5-lts.1",
