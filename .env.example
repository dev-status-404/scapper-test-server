# Server
NODE_ENV=development
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=wow_db
DB_USER=root
DB_PASSWORD=
MONGODB_URI=mongodb://localhost:27017/scapper_db

# Security
# IMPORTANT: Generate a secure 32-byte key using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_ENCRYPTION_KEY=your_cookie_encryption_key_here

# JWT
JWT_SECRET=your_jwt_secret_key
JWT_ACCESS_EXPIRATION_MINUTES=30
JWT_REFRESH_EXPIRATION_DAYS=30
JWT_RESET_PASSWORD_EXPIRATION_MINUTES=10
JWT_VERIFY_EMAIL_EXPIRATION_MINUTES=10

# Email
SMTP_HOST=email-server
SMTP_PORT=587
SMTP_USERNAME=email@example.com
SMTP_PASSWORD=email_password
EMAIL_FROM=support@example.com

# Frontend
FRONTEND_URL=http://localhost:3001

# Observability - Sentry
SENTRY_ENABLED=true
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=1.0.0
SENTRY_TRACES_SAMPLE_RATE=1
SENTRY_SEND_DEFAULT_PII=false

# Observability - Datadog
DD_TRACE_ENABLED=false
DD_SERVICE=scrapper-backend
DD_ENV=development
DD_VERSION=1.0.0
DD_TRACE_AGENT_URL=http://127.0.0.1:8126
DD_TRACE_SAMPLE_RATE=1
DD_LOGS_INJECTION=true
DD_RUNTIME_METRICS_ENABLED=true
DD_PROFILING_ENABLED=false
DD_TRACE_STARTUP_LOGS=false

# Public backend URL used by email open/click tracking links
API_BASE_URL=http://localhost:3000
APP_URL=http://localhost:3000

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_CURRENCY=usd

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_S3_BUCKET=woowsocial
AWS_CLOUDFRONT_URL=https://d3owfp13tbhhin.cloudfront.net

# Instagram providers
APIFY_API_KEY=apify_api_your_token_here
APIFY_INSTAGRAM_PROFILE_ACTOR_ID=dSCLg0C3YEZ83HzYX
# Optional: only set after verifying the selected actors support the requested direction.
APIFY_INSTAGRAM_FOLLOWERS_ACTOR_ID=
APIFY_INSTAGRAM_FOLLOWING_ACTOR_ID=
APIFY_MAX_PROFILE_CHUNK_SIZE=100
APIFY_MAX_PROFILE_CHUNK_SIZE_LARGE=500
APIFY_MAX_CONCURRENT_RUNS_PER_USER=2
APIFY_MAX_CONCURRENT_RUNS_GLOBAL=10
APIFY_MAX_CONCURRENT_RUNS_PER_TARGET=2
APIFY_MAX_CONCURRENT_PROFILE_ENRICHMENT_RUNS=5
APIFY_MAX_COST_USD_PER_JOB=10
APIFY_ESTIMATED_PROFILE_COST_USD=0.002
APIFY_WEBHOOK_URL=https://your-api.example.com/api/beta-insta/webhooks/apify/instagram
APIFY_WEBHOOK_SECRET=replace_with_random_webhook_secret
STEADY_API_KEY=steady_api_key_here

# Instagram proxy pool
PROXY_HOST=proxy.example.com
PROXY_USERNAME=proxy_username
PROXY_PASSWORD=proxy_password
PROXY_PORTS=10001,10002,10003

# Instagram scale and stage limits
INSTAGRAM_DEEP_SCAN_ENABLED=false
INSTAGRAM_DEEP_SCAN_MAX_URLS_PER_JOB=50
INSTAGRAM_DEEP_SCAN_CONCURRENCY=5
INSTAGRAM_FOLLOWERS_WORKER_CONCURRENCY=5
INSTAGRAM_FOLLOWERS_WORKER_RATE_LIMIT_ENABLED=false
INSTAGRAM_FOLLOWERS_WORKER_LIMIT_MAX=5
INSTAGRAM_FOLLOWERS_WORKER_LIMIT_DURATION_MS=1000
DEEP_SCAN_ENABLED=false
DEEP_SCAN_RELATIONSHIP_ENABLED=false
DEEP_SCAN_INLINE_SINGLE_PROFILE=false
DEEP_SCAN_TIMEOUT_MS=15000
DEEP_SCAN_RETRY_DELAY_MS=5000
DEEP_SCAN_MAX_ATTEMPTS=3
DEEP_SCAN_MAX_REDIRECTS=3
DEEP_SCAN_MAX_CONTENT_BYTES=524288
DEEP_SCAN_MAX_PAGES_PER_DOMAIN=3
DEEP_SCAN_CACHE_TTL_DAYS=30
DEEP_SCAN_CONCURRENCY_GLOBAL=10
DEEP_SCAN_CONCURRENCY_PER_USER=2
DEEP_SCAN_CONCURRENCY_PER_DOMAIN=1
DEEP_SCAN_USER_AGENT=
INSTAGRAM_ENRICHMENT_DEFAULT_LIMIT=100
INSTAGRAM_ENRICHMENT_MAX_LIMIT=3000
INSTAGRAM_RELATIONSHIP_MAX_LIMIT_FREE_PLAN=100
INSTAGRAM_RELATIONSHIP_MAX_LIMIT_PAID_PLAN=3000
INSTAGRAM_RELATIONSHIP_MAX_LIMIT_ENTERPRISE=1000000
